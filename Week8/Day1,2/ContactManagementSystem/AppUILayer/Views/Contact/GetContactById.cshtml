@model DataAccessLayer.Models.ContactInfo

<!DOCTYPE html>
<html>
<head>
    <title>Contact Details - Dapper</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background-color: #f4f4f4;
        }
        .container {
            max-width: 600px;
            margin: auto;
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        h1 { text-align: center; color: #333; }
        .details { margin-top: 20px; }
        .detail-row { padding: 10px; border-bottom: 1px solid #ddd; }
        .label { font-weight: bold; display: inline-block; width: 130px; }
        .button {
            display: inline-block;
            margin-top: 20px;
            padding: 10px 20px;
            background-color: #007bff;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }
        .button-group { text-align: center; margin-top: 20px; }
        .badge {
            text-align: center;
            margin-top: 10px;
            padding: 5px;
            background-color: #28a745;
            color: white;
            border-radius: 5px;
            font-size: 12px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>📄 Contact Details</h1>
        <div class="badge">⚡ Data fetched using Dapper with SQL JOIN</div>
        
        <div class="details">
            <div class="detail-row"><span class="label">Contact ID:</span> @Model.ContactId</div>
            <div class="detail-row"><span class="label">First Name:</span> @Model.FirstName</div>
            <div class="detail-row"><span class="label">Last Name:</span> @Model.LastName</div>
            <div class="detail-row"><span class="label">Email ID:</span> @Model.EmailId</div>
            <div class="detail-row"><span class="label">Mobile No:</span> @Model.MobileNo</div>
            <div class="detail-row"><span class="label">Designation:</span> @Model.Designation</div>
            <div class="detail-row"><span class="label">Company:</span> @Model.CompanyName</div>
            <div class="detail-row"><span class="label">Department:</span> @Model.DepartmentName</div>
        </div>
        
        <div class="button-group">
            <a href="@Url.Action("ShowContacts")" class="button">← Back to All Contacts</a>
            <a href="@Url.Action("EditContact", new { id = Model.ContactId })" class="button" style="background-color:#ffc107; color:#333;">✏️ Edit</a>
        </div>
    </div>
</body>
</html>