@model DataAccessLayer.Models.ContactInfo

<!DOCTYPE html>
<html>
<head>
    <title>Delete Contact - Dapper</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background-color: #f4f4f4;
        }
        .container {
            max-width: 600px;
            margin: auto;
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        h1 { text-align: center; color: #dc3545; }
        .warning {
            background-color: #f8d7da;
            color: #721c24;
            padding: 15px;
            border-radius: 5px;
            text-align: center;
            margin-bottom: 20px;
        }
        .details { margin-top: 20px; }
        .detail-row { padding: 10px; border-bottom: 1px solid #ddd; }
        .label { font-weight: bold; display: inline-block; width: 130px; }
        .button-group { text-align: center; margin-top: 20px; }
        .btn-delete {
            padding: 10px 20px;
            background-color: #dc3545;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }
        .btn-cancel {
            padding: 10px 20px;
            background-color: #6c757d;
            color: white;
            text-decoration: none;
            border-radius: 5px;
            display: inline-block;
            margin-left: 10px;
        }
        .badge {
            text-align: center;
            margin-top: 10px;
            padding: 5px;
            background-color: #dc3545;
            color: white;
            border-radius: 5px;
            font-size: 12px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🗑️ Delete Contact</h1>
        <div class="badge">⚡ Data will be deleted using Dapper DELETE</div>
        
        <div class="warning">
            ⚠️ Are you sure you want to delete this contact? This action cannot be undone.
        </div>
        
        <div class="details">
            <div class="detail-row"><span class="label">Contact ID:</span> @Model.ContactId</div>
            <div class="detail-row"><span class="label">First Name:</span> @Model.FirstName</div>
            <div class="detail-row"><span class="label">Last Name:</span> @Model.LastName</div>
            <div class="detail-row"><span class="label">Email ID:</span> @Model.EmailId</div>
            <div class="detail-row"><span class="label">Mobile No:</span> @Model.MobileNo</div>
            <div class="detail-row"><span class="label">Designation:</span> @Model.Designation</div>
            <div class="detail-row"><span class="label">Company:</span> @Model.CompanyName</div>
            <div class="detail-row"><span class="label">Department:</span> @Model.DepartmentName</div>
        </div>
        
        <div class="button-group">
            <form asp-action="DeleteContact" method="post">
                <input type="hidden" name="contactId" value="@Model.ContactId" />
                <button type="submit" class="btn-delete">✅ Confirm Delete</button>
                <a href="@Url.Action("ShowContacts")" class="btn-cancel">❌ Cancel</a>
            </form>
        </div>
    </div>
</body>
</html>