@model ContactManagementDI.Models.ContactInfo

<!DOCTYPE html>
<html>
<head>
    <title>Contact Details</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background-color: #f4f4f4;
        }
        .container {
            max-width: 600px;
            margin: auto;
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        h1 {
            text-align: center;
            color: #333;
        }
        .details {
            margin-top: 20px;
        }
        .detail-row {
            padding: 10px;
            border-bottom: 1px solid #ddd;
        }
        .label {
            font-weight: bold;
            display: inline-block;
            width: 120px;
        }
        .value {
            display: inline-block;
        }
        .button {
            display: inline-block;
            margin-top: 20px;
            padding: 10px 20px;
            background-color: #007bff;
            color: white;
            text-decoration: none;
            border-radius: 5px;
            text-align: center;
        }
        .button:hover {
            background-color: #0056b3;
        }
        .back-link {
            text-align: center;
            margin-top: 20px;
        }
        .di-badge {
            text-align: center;
            margin-top: 10px;
            padding: 5px;
            background-color: #17a2b8;
            color: white;
            border-radius: 5px;
            font-size: 12px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>📄 Contact Details</h1>
        <div class="di-badge">⚡ Data fetched via IContactService.GetContactById()</div>
        
        <div class="details">
            <div class="detail-row">
                <span class="label">Contact ID:</span>
                <span class="value">@Model.ContactId</span>
            </div>
            <div class="detail-row">
                <span class="label">First Name:</span>
                <span class="value">@Model.FirstName</span>
            </div>
            <div class="detail-row">
                <span class="label">Last Name:</span>
                <span class="value">@Model.LastName</span>
            </div>
            <div class="detail-row">
                <span class="label">Company Name:</span>
                <span class="value">@Model.CompanyName</span>
            </div>
            <div class="detail-row">
                <span class="label">Email ID:</span>
                <span class="value">@Model.EmailId</span>
            </div>
            <div class="detail-row">
                <span class="label">Mobile No:</span>
                <span class="value">@Model.MobileNo</span>
            </div>
            <div class="detail-row">
                <span class="label">Designation:</span>
                <span class="value">@Model.Designation</span>
            </div>
        </div>
        
        <div class="back-link">
            <a href="@Url.Action("ShowContacts")" class="button">← Back to All Contacts</a>
        </div>
    </div>
</body>
</html>